#!/usr/bin/env python3
"""Pre-Edit Guard: 指定ファイルの直接編集をブロックする Hook"""
import sys, json, io, os
sys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding="utf-8")
sys.stderr = io.TextIOWrapper(sys.stderr.buffer, encoding="utf-8")

# === カスタマイズ: 保護対象ファイルをここに列挙 ===
PROTECTED_FILES = ["index.html"]

data = json.load(sys.stdin)
tool_input = data.get("tool_input", {})
file_path = tool_input.get("file_path", "")
basename = os.path.basename(file_path)

if basename in PROTECTED_FILES:
    print(f"[BLOCKED] {basename} は直接編集禁止です。", file=sys.stderr)
    print(f"  CSS変更 → css/style.css", file=sys.stderr)
    print(f"  JS変更  → js/app.js", file=sys.stderr)
    sys.exit(1)

sys.exit(0)
