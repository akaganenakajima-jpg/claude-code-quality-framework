#!/usr/bin/env python3
"""Pre-Deploy Guard: デプロイ前にE2Eテスト通過を強制する Hook"""
import sys, json, io, os, time
sys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding="utf-8")
sys.stderr = io.TextIOWrapper(sys.stderr.buffer, encoding="utf-8")

# === カスタマイズ ===
DEPLOY_CMD = "deploy"           # デプロイコマンドに含まれる文字列
E2E_MARKER = ".e2e_passed"      # E2Eテスト通過マーカーファイル
MAX_AGE_MIN = 30                # マーカー有効期限（分）

data = json.load(sys.stdin)
tool_input = data.get("tool_input", {})
command = tool_input.get("command", "")

if DEPLOY_CMD not in command:
    sys.exit(0)

marker = os.path.join(os.getcwd(), E2E_MARKER)
if not os.path.exists(marker):
    print(f"[BLOCKED] E2Eテスト未実施。先に E2E テストを実行してください。", file=sys.stderr)
    print(f"  マーカーファイル: {marker}", file=sys.stderr)
    sys.exit(1)

age_min = (time.time() - os.path.getmtime(marker)) / 60
if age_min > MAX_AGE_MIN:
    print(f"[BLOCKED] E2Eテスト結果が古い（{age_min:.0f}分前）。再実行してください。", file=sys.stderr)
    sys.exit(1)

print(f"[OK] E2Eテスト通過済み（{age_min:.0f}分前）", file=sys.stderr)
sys.exit(0)
